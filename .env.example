# 备份中心环境变量配置
# 复制此文件为 .env 并修改相应配置

# 数据库配置
DATABASE_URL=postgresql://postgres:postgres_password_2026@localhost:5432/rao5201_db
REDIS_URL=redis://localhost:6379/0

# 备份配置
BACKUP_DIR=/backups
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPTION_KEY=your-encryption-key-change-this

# 云存储配置（可选）
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=rao5201-backups
S3_REGION=us-east-1

# 告警配置
ALERT_EMAIL=rao5201@126.com
ALERT_WEBHOOK=
ALERT_DINGTALK_TOKEN=

# 同步配置
SYNC_SCHEDULE=0 4 * * *
SYNC_ENABLED=true
